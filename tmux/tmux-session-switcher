#!/usr/bin/env bash

# Catppuccin Mocha ANSI colors
TEAL='\033[38;2;148;226;213m'
PEACH='\033[38;2;250;179;135m'
GREEN='\033[38;2;166;227;161m'
BLUE='\033[38;2;137;180;250m'    # Catppuccin blue #89b4fa
MAUVE='\033[38;2;203;166;247m'   # Catppuccin mauve #cba6f7
OVERLAY='\033[38;2;108;112;134m'
TEXT='\033[38;2;205;214;244m'
RESET='\033[0m'

# Nerd Font icons by window type
ICON_CLAUDE="${PEACH}󰚩${RESET}"   # nf-md-creation (sparkle) — claude running
ICON_SHELL="${OVERLAY}${RESET}"  # nf-dev-terminal — shell window
ICON_OTHER="${OVERLAY}${RESET}"  # nf-cod-gear — anything else

window_icon() {
  local claude_status=$1 cmd=$2
  case "$claude_status" in
    running) printf '%b' "$ICON_CLAUDE" ;;
    done)    printf '%b' "${GREEN}󰚩${RESET}" ;;
    *)
      case "$cmd" in
        zsh|bash|fish) printf '%b' "$ICON_SHELL" ;;
        *)             printf '%b' "$ICON_OTHER" ;;
      esac
      ;;
  esac
}

relative_time() {
  local seconds=$1
  if (( seconds < 60 )); then
    echo "${seconds}s"
  elif (( seconds < 3600 )); then
    echo "$(( seconds / 60 ))m"
  elif (( seconds < 86400 )); then
    echo "$(( seconds / 3600 ))h"
  else
    echo "$(( seconds / 86400 ))d"
  fi
}

# Strip ✳ prefix from window names set by the claude() shell function
strip_claude_prefix() {
  echo "${1#✳ }"
}

# Claude status for a single window: "running", "done", or "none"
window_claude_status() {
  local target=$1  # session:win_idx
  local running done_flag
  running=$(tmux show-options -wqv -t "$target" @is_claude_running 2>/dev/null)
  done_flag=$(tmux show-options -wqv -t "$target" @claude_done 2>/dev/null)
  if [[ "$running" == "1" ]]; then
    echo "running"
  elif [[ -n "$done_flag" ]]; then
    echo "done"
  else
    echo "none"
  fi
}


build_list() {
  local now
  now=$(date +%s)
  local idx=0
  while IFS='|' read -r _created name last_activity; do
    idx=$(( idx + 1 ))
    local age=$(( now - last_activity ))
    local rel
    rel=$(relative_time "$age")

    # Session row: display \t s:session_name
    printf "%b   ${TEXT}%-22s${RESET}${OVERLAY} · %s${RESET}\t%s\n" \
      "${MAUVE}${idx}${RESET}" "$name" "$rel" "s:${name}"

    # Window rows with composite labels (1a, 1b, 2a, ...)
    local win_counter=0
    while IFS='|' read -r win_idx win_name win_cmd win_path; do
      win_counter=$(( win_counter + 1 ))
      local letter wst wicon clean_name detail dir_name
      letter=$(printf "\\x$(printf '%02x' $((96 + win_counter)))")
      wst=$(window_claude_status "${name}:${win_idx}")
      wicon=$(window_icon "$wst" "$win_cmd")
      clean_name=$(strip_claude_prefix "$win_name")
      dir_name=$(basename "$win_path")
      case "$wst" in
        running) detail="running · $dir_name" ;;
        done)    detail="done · $dir_name"    ;;
        *)       detail="$dir_name"           ;;
      esac
      printf " %b %b ${TEXT}%-18s${RESET}${OVERLAY} · %s${RESET}\t%s\n" \
        "${MAUVE}${idx}${letter}${RESET}" "$wicon" "$clean_name" "$detail" "w:${name}:${win_idx}"
    done < <(tmux list-windows -t "$name" -F '#{window_index}|#{window_name}|#{pane_current_command}|#{pane_current_path}' 2>/dev/null)

  done < <(tmux list-sessions -F '#{session_created}|#{session_name}|#{session_last_attached}' 2>/dev/null | sort -t'|' -k1 -n)
}

preview_session() {
  local session=$1
  local path
  path=$(tmux display-message -p -t "$session" '#{session_path}' 2>/dev/null | sed "s|$HOME|~|")
  printf "${TEAL}%s${RESET}\n${OVERLAY}%s${RESET}\n\n" "$session" "$path"

  printf "${PEACH}WINDOWS${RESET}\n"
  while IFS='|' read -r win_idx win_name win_cmd win_path; do
    local wst wicon clean_name detail dir_name
    wst=$(window_claude_status "${session}:${win_idx}")
    wicon=$(window_icon "$wst" "$win_cmd")
    clean_name=$(strip_claude_prefix "$win_name")
    dir_name=$(basename "$win_path")
    case "$wst" in
      running) detail="running · $dir_name" ;;
      done)    detail="done · $dir_name"    ;;
      *)       detail="$dir_name"           ;;
    esac
    printf "${PEACH}%s:${RESET} %b ${TEXT}%s${RESET} ${OVERLAY}· %s${RESET}\n" \
      "$win_idx" "$wicon" "$clean_name" "$detail"
  done < <(tmux list-windows -t "$session" -F '#{window_index}|#{window_name}|#{pane_current_command}|#{pane_current_path}' 2>/dev/null)

  local win_count attached created now age created_rel attach_str
  win_count=$(tmux list-windows -t "$session" 2>/dev/null | wc -l | tr -d ' ')
  attached=$(tmux display-message -p -t "$session" '#{session_attached}' 2>/dev/null)
  created=$(tmux display-message -p -t "$session" '#{session_created}' 2>/dev/null)
  now=$(date +%s)
  age=$(( now - created ))
  created_rel=$(relative_time "$age")
  [[ "$attached" -gt 0 ]] && attach_str="attached" || attach_str="detached"

  printf "\n${PEACH}INFO${RESET}\n${OVERLAY}%s · %s windows · created %s ago${RESET}\n" \
    "$attach_str" "$win_count" "$created_rel"
}

# Extract session name from hidden field (s:name or w:name:win_idx)
parse_session() {
  local field=$1
  case "$field" in
    s:*) echo "${field#s:}" ;;
    w:*) echo "${field#w:}" | cut -d: -f1 ;;
  esac
}

# --preview mode
if [[ "$1" == "--preview" ]]; then
  preview_session "$(parse_session "$2")"
  exit 0
fi

# --list mode (reload after ctrl-d)
if [[ "$1" == "--list" ]]; then
  build_list
  exit 0
fi

script_path="$(realpath "$0")"

selected=$(build_list | fzf \
  --ansi \
  --no-sort \
  --layout=reverse-list \
  --delimiter=$'\t' \
  --with-nth=1 \
  --preview="$script_path --preview {2}" \
  --preview-window='right:45%:wrap' \
  --bind="ctrl-d:execute-silent(tmux kill-session -t \$(echo {2} | sed 's/^[sw]://;s/:.*//'))+reload($script_path --list)" \
  --prompt='  sessions  ❯ ' \
  --pointer='▶' \
  --header='enter: switch  ctrl-d: kill session' \
  --color='bg+:#313244,bg:#1e1e2e,spinner:#f5e0dc,hl:#f38ba8' \
  --color='fg:#cdd6f4,header:#f38ba8,info:#cba6f7,pointer:#f5e0dc' \
  --color='marker:#b4befe,fg+:#cdd6f4,prompt:#cba6f7,hl+:#f38ba8' \
)

[[ -z "$selected" ]] && exit 0

field=$(printf '%s' "$selected" | cut -f2)
session_name=$(parse_session "$field")

tmux switch-client -t "$session_name"

# If a specific window was selected, jump to it
if [[ "$field" == w:* ]]; then
  win_idx=$(echo "$field" | cut -d: -f3)
  tmux select-window -t "${session_name}:${win_idx}"
fi
