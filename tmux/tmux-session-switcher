#!/usr/bin/env bash

US=$'\x1f'  # Unit separator — fzf field delimiter

# Catppuccin Mocha ANSI colors
TEAL='\033[38;2;148;226;213m'
PEACH='\033[38;2;250;179;135m'
GREEN='\033[38;2;166;227;161m'
BLUE='\033[38;2;137;180;250m'    # Catppuccin blue #89b4fa
MAUVE='\033[38;2;203;166;247m'   # Catppuccin mauve #cba6f7
OVERLAY='\033[38;2;108;112;134m'
TEXT='\033[38;2;205;214;244m'
RESET='\033[0m'

# Nerd Font icons by window type
ICON_CLAUDE="${PEACH}󰚩${RESET}"   # nf-md-creation (sparkle) — claude running
ICON_SHELL="${OVERLAY}${RESET}"  # nf-dev-terminal — shell window
ICON_OTHER="${OVERLAY}${RESET}"  # nf-cod-gear — anything else

git_branch_for_path() {
  git -C "$1" branch --show-current 2>/dev/null || true
}

window_icon() {
  local claude_status=$1 cmd=$2
  case "$claude_status" in
    running) printf '%b' "$ICON_CLAUDE" ;;
    done)    printf '%b' "${GREEN}󰚩${RESET}" ;;
    *)
      case "$cmd" in
        zsh|bash|fish) printf '%b' "$ICON_SHELL" ;;
        *)             printf '%b' "$ICON_OTHER" ;;
      esac
      ;;
  esac
}

relative_time() {
  local seconds=$1
  if (( seconds < 60 )); then
    echo "${seconds}s"
  elif (( seconds < 3600 )); then
    echo "$(( seconds / 60 ))m"
  elif (( seconds < 86400 )); then
    echo "$(( seconds / 3600 ))h"
  else
    echo "$(( seconds / 86400 ))d"
  fi
}

# Strip ✳ prefix from window names set by the claude() shell function
strip_claude_prefix() {
  echo "${1#✳ }"
}

# Human-readable label for a pane command: shells → "shell", others pass through
pane_label_for_cmd() {
  local cmd=$1
  case "$cmd" in
    zsh|bash|fish) echo "shell" ;;
    *)             echo "$cmd" ;;
  esac
}

# Claude status from pre-fetched values: "running", "done", or "none"
# $1 = @is_claude_running value, $2 = @claude_done value
window_claude_status() {
  local running=$1 done_flag=$2
  if [[ "$running" == "1" ]]; then
    echo "running"
  elif [[ -n "$done_flag" ]]; then
    echo "done"
  else
    echo "none"
  fi
}


# $1=age_seconds → "active" (within 3 days) or "inactive"
category_for_age() {
  local age=$1
  if (( age <= 259200 )); then echo "active"
  else echo "inactive"
  fi
}

# Emit a dimmed category header line (3 US-delimited fields, field 3 empty = non-selectable)
emit_header() {
  local label=$1
  printf '%b── %s ─────────────────────────────────%b%s%s%s\n' \
    "${OVERLAY}" "$label" "${RESET}" "$US" "$US" ""
}

# Emit a blank spacer line (3 US-delimited fields, field 3 empty = non-selectable)
emit_spacer() {
  printf ' %s%s\n' "$US" "$US"
}

build_list() {
  local track_session="${1:-}"
  local now sessions_raw windows_raw panes_raw
  now=$(date +%s)

  # Three batched tmux calls instead of N+NM per-session/window calls
  sessions_raw=$(tmux list-sessions -F '#{session_last_attached}|#{session_name}' 2>/dev/null)
  windows_raw=$(tmux list-windows -a -F '#{session_name}|#{window_index}|#{window_name}|#{pane_current_command}|#{pane_current_path}|#{window_active}|#{@is_claude_running}|#{@claude_done}' 2>/dev/null)
  panes_raw=$(tmux list-panes -a -F '#{session_name}|#{window_index}|#{pane_index}|#{pane_current_command}|#{pane_current_path}|#{pane_active}|#{@is_claude_running}|#{@claude_done}' 2>/dev/null)

  # Separate _default from all others, then sort each group alphabetically
  local default_entry active_entries inactive_entries
  default_entry=$(printf '%s\n' "$sessions_raw" | awk -F'|' '$2 == "_default"')
  local other_entries
  other_entries=$(printf '%s\n' "$sessions_raw" | awk -F'|' '$2 != "_default"')

  active_entries=$(
    while IFS='|' read -r ts name; do
      [[ -z "$name" ]] && continue
      local age=$(( now - ts ))
      [[ "$(category_for_age "$age")" == "active" ]] && printf '%s|%s\n' "$ts" "$name"
    done <<< "$other_entries" | sort -t'|' -k2
  )
  inactive_entries=$(
    while IFS='|' read -r ts name; do
      [[ -z "$name" ]] && continue
      local age=$(( now - ts ))
      [[ "$(category_for_age "$age")" == "inactive" ]] && printf '%s|%s\n' "$ts" "$name"
    done <<< "$other_entries" | sort -t'|' -k2
  )

  # Build ordered list: _default first, then active, then inactive
  local ordered=""
  [[ -n "$default_entry" ]] && ordered+="$default_entry"$'\n'
  [[ -n "$active_entries" ]] && ordered+="$active_entries"$'\n'
  ordered+="INACTIVE_BOUNDARY"$'\n'
  [[ -n "$inactive_entries" ]] && ordered+="$inactive_entries"$'\n'

  local output=""
  local line_num=0
  local start_pos=1
  local idx=0
  local emitted_inactive_header=0

  while IFS='|' read -r last_attached name; do
    if [[ "$last_attached" == "INACTIVE_BOUNDARY" ]]; then
      [[ -n "$inactive_entries" ]] || continue
      # Spacer + Inactive header
      line_num=$(( line_num + 1 ))
      output+=$(emit_spacer)
      output+=$'\n'
      line_num=$(( line_num + 1 ))
      output+=$(emit_header "Inactive")
      output+=$'\n'
      emitted_inactive_header=1
      continue
    fi
    [[ -z "$name" ]] && continue
    idx=$(( idx + 1 ))
    local age=$(( now - last_attached ))
    local rel
    rel=$(relative_time "$age")

    # Spacer before each session except: the very first, and the one directly after a header
    if [[ $idx -gt 1 && "$emitted_inactive_header" -ne 1 ]]; then
      line_num=$(( line_num + 1 ))
      output+=$(emit_spacer)
      output+=$'\n'
    fi
    # Clear the "just emitted header" flag after the first inactive session row
    [[ "$emitted_inactive_header" -eq 1 ]] && emitted_inactive_header=2

    line_num=$(( line_num + 1 ))
    [[ -n "$track_session" && "$name" == "$track_session" ]] && start_pos=$line_num

    # Session row: label+name \x1f detail \x1f key
    output+=$(printf '%b   %b%-22s%b%s%b · %s%b%s%b' \
      "${MAUVE}${idx}${RESET}" "${TEXT}" "$name" "${RESET}" \
      "$US" "${OVERLAY}" "$rel" "${RESET}" "$US" "s:${name}")
    output+=$'\n'

    # Window rows — matched from batched data (exact session name, no regex)
    local win_counter=0
    local session_windows
    session_windows=$(printf '%s\n' "$windows_raw" | \
      awk -F'|' -v s="$name" '$1 == s { for(i=2;i<=NF;i++) printf "%s%s", $i, (i<NF?"|":"\n") }')

    while IFS='|' read -r win_idx win_name win_cmd win_path _active w_running w_done; do
      [[ -z "$win_idx" ]] && continue
      win_counter=$(( win_counter + 1 ))
      line_num=$(( line_num + 1 ))
      local letter wst wicon clean_name detail dir_name branch branch_str
      letter=$(printf "\\x$(printf '%02x' $((96 + win_counter)))")
      wst=$(window_claude_status "$w_running" "$w_done")
      wicon=$(window_icon "$wst" "$win_cmd")
      clean_name=$(strip_claude_prefix "$win_name")
      # Dedup: window name same as session and idle shell → show "shell"
      if [[ "$clean_name" == "$name" && "$win_cmd" =~ ^(zsh|bash|fish)$ ]]; then
        clean_name="shell"
      fi

      # Multi-pane: check panes_raw for this session+window
      local window_panes pane_count
      window_panes=$(printf '%s\n' "$panes_raw" | \
        awk -F'|' -v s="$name" -v w="$win_idx" '$1 == s && $2 == w { for(i=3;i<=NF;i++) printf "%s%s", $i, (i<NF?"|":"\n") }')
      pane_count=$(printf '%s\n' "$window_panes" | awk 'NF>0 {n++} END {print n+0}')

      if [[ "$pane_count" -gt 1 ]]; then
        local combined_label=""
        while IFS='|' read -r _pidx p_cmd _p_path _pactive _p_running _p_done; do
          [[ -z "$p_cmd" ]] && continue
          local plabel
          plabel=$(pane_label_for_cmd "$p_cmd")
          combined_label="${combined_label:+$combined_label / }$plabel"
        done <<< "$window_panes"
        clean_name="$combined_label"
      fi

      dir_name=$(basename "$win_path")
      # Git branch — shown in blue when not main/master
      branch=$(git_branch_for_path "$win_path")
      branch_str=""
      if [[ -n "$branch" && "$branch" != "main" && "$branch" != "master" ]]; then
        branch_str=$(printf '%b' " ${BLUE}${branch}${RESET}")
      fi
      # Column order: repo [branch] · status
      case "$wst" in
        running) detail="${dir_name}${branch_str} · running" ;;
        done)    detail="${dir_name}${branch_str} · done"    ;;
        *)       detail="${dir_name}${branch_str}"           ;;
      esac
      # Window row: label+name \x1f detail \x1f key
      output+=$(printf ' %b %b %b%-18s%b%s%b · %s%b%s%b' \
        "${MAUVE}${idx}${letter}${RESET}" "$wicon" "${TEXT}" "$clean_name" "${RESET}" \
        "$US" "${OVERLAY}" "$detail" "${RESET}" "$US" "w:${name}:${win_idx}")
      output+=$'\n'
    done <<< "$session_windows"

  done <<< "$ordered"

  if [[ -n "$track_session" ]]; then
    printf 'POS:%d\n' "$start_pos"
  fi
  printf '%s' "$output"
}

preview_session() {
  local session=$1
  local session_path display_path
  session_path=$(tmux display-message -p -t "$session" '#{session_path}' 2>/dev/null)
  display_path=$(printf '%s' "$session_path" | sed "s|$HOME|~|")
  printf "${TEAL}%s${RESET}\n${OVERLAY}%s${RESET}\n\n" "$session" "$display_path"

  # Git info
  if git -C "$session_path" rev-parse --is-inside-work-tree &>/dev/null 2>&1; then
    local branch dirty status_str commit_msg commit_ts commit_age_str status_color
    branch=$(git -C "$session_path" branch --show-current 2>/dev/null)
    dirty=$(git -C "$session_path" status --porcelain 2>/dev/null | wc -l | tr -d ' ')
    status_str="clean"
    [[ "$dirty" -gt 0 ]] && status_str="${dirty} changed"
    printf "${PEACH}GIT${RESET}  ${BLUE}%s${RESET}\n" "$branch"
    commit_msg=$(git -C "$session_path" log -1 --format='%s' 2>/dev/null)
    commit_ts=$(git -C "$session_path" log -1 --format='%ct' 2>/dev/null)
    commit_age_str=""
    if [[ -n "$commit_ts" ]]; then
      local _now_git
      _now_git=$(date +%s)
      commit_age_str=$(relative_time $(( _now_git - commit_ts )))
    fi
    if [[ "$dirty" -gt 0 ]]; then status_color="${PEACH}"; else status_color="${GREEN}"; fi
    if [[ -n "$commit_msg" ]]; then
      printf "${status_color}%s${OVERLAY} · %s" "$status_str" "$commit_msg"
      [[ -n "$commit_age_str" ]] && printf " (%s ago)" "$commit_age_str"
      printf "${RESET}\n"
    else
      printf "${status_color}%s${RESET}\n" "$status_str"
    fi
    printf "\n"
  fi

  printf "${PEACH}WINDOWS${RESET}\n"
  local panes_data
  panes_data=$(tmux list-panes -s -t "$session" -F '#{window_index}|#{pane_index}|#{window_name}|#{pane_current_command}|#{pane_current_path}|#{pane_active}|#{@is_claude_running}|#{@claude_done}' 2>/dev/null)
  local window_indices
  window_indices=$(printf '%s\n' "$panes_data" | awk -F'|' 'NF>0 {print $1}' | sort -un)

  while IFS= read -r windex; do
    [[ -z "$windex" ]] && continue
    local win_panes pane_count
    win_panes=$(printf '%s\n' "$panes_data" | awk -F'|' -v w="$windex" '$1 == w')
    pane_count=$(printf '%s\n' "$win_panes" | awk 'NF>0 {n++} END {print n+0}')

    # Prefer active pane for window header info; fall back to first pane
    local active_pane
    active_pane=$(printf '%s\n' "$win_panes" | awk -F'|' '
      NR==1 { first=$0 }
      $6=="1" { print; found=1; exit }
      END { if (!found) print first }
    ')

    local win_idx pane_idx win_name win_cmd win_path _active w_running w_done
    IFS='|' read -r win_idx pane_idx win_name win_cmd win_path _active w_running w_done <<< "$active_pane"

    local wst wicon clean_name detail dir_name
    wst=$(window_claude_status "$w_running" "$w_done")
    wicon=$(window_icon "$wst" "$win_cmd")
    clean_name=$(strip_claude_prefix "$win_name")
    dir_name=$(basename "$win_path")
    case "$wst" in
      running) detail="$dir_name · running" ;;
      done)    detail="$dir_name · done"    ;;
      *)       detail="$dir_name"           ;;
    esac
    printf "${PEACH}%s:${RESET} %b ${TEXT}%s${RESET} ${OVERLAY}· %s${RESET}\n" \
      "$win_idx" "$wicon" "$clean_name" "$detail"

    if [[ "$pane_count" -gt 1 ]]; then
      while IFS='|' read -r _widx _pidx _wname p_cmd p_path _pactive p_running p_done; do
        local p_wst p_wicon p_dir
        p_wst=$(window_claude_status "$p_running" "$p_done")
        p_wicon=$(window_icon "$p_wst" "$p_cmd")
        p_dir=$(basename "$p_path")
        [[ "$p_wicon" == "$wicon" && "$p_dir" == "$dir_name" ]] && continue
        printf "   %b ${TEXT}%s${RESET}\n" "$p_wicon" "$p_dir"
      done <<< "$win_panes"
    fi
  done <<< "$window_indices"

  local win_count attached created now age created_rel attach_str
  win_count=$(printf '%s\n' "$panes_data" | awk -F'|' 'NF>0 && !seen[$1]++ {n++} END {print n+0}')
  attached=$(tmux display-message -p -t "$session" '#{session_attached}' 2>/dev/null)
  created=$(tmux display-message -p -t "$session" '#{session_created}' 2>/dev/null)
  now=$(date +%s)
  age=$(( now - created ))
  created_rel=$(relative_time "$age")
  [[ "$attached" -gt 0 ]] && attach_str="attached" || attach_str="detached"

  printf "\n${PEACH}INFO${RESET}\n${OVERLAY}%s · %s windows · created %s ago${RESET}\n" \
    "$attach_str" "$win_count" "$created_rel"
}

# Extract session name from hidden field (s:name or w:name:win_idx)
parse_session() {
  local field=$1
  case "$field" in
    s:*) echo "${field#s:}" ;;
    w:*) echo "${field#w:}" | cut -d: -f1 ;;
  esac
}

# Switch to the selected session/window; exits cleanly if the session was killed
# between fzf display and selection.
handle_selection() {
  local field="$1"
  local session_name
  session_name=$(parse_session "$field")
  tmux switch-client -t "$session_name" || exit 0

  # If a specific window was selected, jump to it
  if [[ "$field" == w:* ]]; then
    local win_idx
    win_idx=$(echo "$field" | cut -d: -f3)
    tmux select-window -t "${session_name}:${win_idx}" || exit 0
  fi
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then

# --preview mode
if [[ "$1" == "--preview" ]]; then
  [[ -z "$2" ]] && exit 0
  case "$2" in s:*|w:*) ;; *) exit 0 ;; esac
  preview_session "$(parse_session "$2")"
  exit 0
fi

# --list mode (reload after ctrl-d)
if [[ "$1" == "--list" ]]; then
  build_list ""
  exit 0
fi

script_path="$(realpath "$0")"
current_session=$(tmux display-message -p '#{session_name}' 2>/dev/null)

list_output=$(build_list "$current_session")
start_pos=$(printf '%s' "$list_output" | head -1 | sed 's/^POS://')
list_body=$(printf '%s' "$list_output" | tail -n +2)

selected=$(printf '%s' "$list_body" | fzf \
  --ansi \
  --no-sort \
  --cycle \
  --layout=reverse-list \
  --delimiter=$'\x1f' \
  --with-nth=1,2 \
  --nth=1 \
  --preview="$script_path --preview {3}" \
  --preview-window='right:35%:wrap' \
  --bind="start:pos($start_pos)" \
  --bind="ctrl-d:execute-silent(tmux kill-session -t \$(echo {3} | sed 's/^[sw]://;s/:.*//'))+reload($script_path --list)" \
  --bind='ctrl-/:toggle-preview' \
  --prompt='  sessions  ❯ ' \
  --pointer='▶' \
  --header='enter: switch  ctrl-d: kill  ctrl-/: preview' \
  --color='bg+:#313244,bg:#1e1e2e,spinner:#f5e0dc,hl:#f38ba8' \
  --color='fg:#cdd6f4,header:#f38ba8,info:#cba6f7,pointer:#f5e0dc' \
  --color='marker:#b4befe,fg+:#cdd6f4,prompt:#cba6f7,hl+:#f38ba8' \
)

[[ -z "$selected" ]] && exit 0

field=$(printf '%s' "$selected" | cut -d$'\x1f' -f3)

# Ignore non-data lines (headers, spacers)
case "$field" in s:*|w:*) ;; *) exit 0 ;; esac

handle_selection "$field"

fi  # end BASH_SOURCE guard
