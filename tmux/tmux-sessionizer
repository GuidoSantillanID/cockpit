#!/usr/bin/env bash

# Derives a tmux session name from a project path.
# Worktrees get a "parent/branch" prefix; dots are replaced with underscores.
session_name_for_path() {
  local path="$1"
  local parent base dir session_name
  parent=$(basename "$(dirname "$(dirname "$path")")")
  base=$(basename "$path")
  dir=$(basename "$(dirname "$path")")

  if [[ "$dir" == ".worktrees" ]]; then
    session_name="${parent}/${base}"
  else
    session_name="$base"
  fi

  echo "$session_name" | tr . _
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then

# Top-level projects + worktrees inside each project
projects=$(find ~/Documents/dev ~/Documents/lab -mindepth 1 -maxdepth 1 -type d)
worktrees=$(find ~/Documents/dev ~/Documents/lab -mindepth 3 -maxdepth 3 -type d -path '*/.worktrees/*')

selected=$(echo -e "$projects\n$worktrees" | fzf)

if [[ -z "$selected" ]]; then
  exit 0
fi

session_name=$(session_name_for_path "$selected")
tmux_running=$(tmux list-sessions 2>/dev/null)

if [[ -z "$TMUX" ]] && [[ -z "$tmux_running" ]]; then
  tmux new-session -s "$session_name" -c "$selected"
  exit 0
fi

if ! tmux has-session -t "$session_name" 2>/dev/null; then
  tmux new-session -d -s "$session_name" -c "$selected"
fi

tmux switch-client -t "$session_name"

fi  # end BASH_SOURCE guard
