#!/usr/bin/env bash
set -euo pipefail

# Test isolation: TMUX_PANE_FOCUS_SOCK overrides the tmux socket,
# TMUX_PANE_FOCUS_TARGET overrides the target for display-message.
_sock_args() { [ -n "${TMUX_PANE_FOCUS_SOCK:-}" ] && echo "-L $TMUX_PANE_FOCUS_SOCK" || true; }
_target_args() { [ -n "${TMUX_PANE_FOCUS_TARGET:-}" ] && echo "-t $TMUX_PANE_FOCUS_TARGET" || true; }

tm()      { tmux $(_sock_args) "$@"; }
tm_info() { tm display-message $(_target_args) -p "$@"; }

# Resolve the active secondary pane ID.
# Returns @secondary if set and alive, otherwise falls back to the last pane.
get_secondary() {
  local secondary
  secondary=$(tm_info '#{@secondary}')
  if [ -n "$secondary" ]; then
    # Verify pane is alive (dead panes return empty output but exit 0)
    local check
    check=$(tm display-message -t "$secondary" -p '#{pane_id}' 2>/dev/null) || true
    if [ -n "$check" ]; then
      echo "$secondary"
      return 0
    fi
  fi
  # Fallback: highest-index pane in the window
  tm list-panes $(_target_args) -F '#{pane_id}' | tail -1
}

case "${1:-}" in
  track)
    pane_idx=$(tm_info '#{pane_index}')
    if [ "$pane_idx" -gt 1 ]; then
      tm set-option -w $(_target_args) @secondary "$(tm_info '#{pane_id}')"
    fi
    ;;
  zoom)
    # Single query for state flags (path queried separately — may contain spaces)
    read -r npanes zoomed pane_idx <<< "$(tm_info '#{window_panes} #{window_zoomed_flag} #{pane_index}')"
    if [ "$npanes" -eq 1 ]; then
      path=$(tm_info '#{pane_current_path}')
      tm split-window -h -l 30% $(_target_args) -c "$path"
      # Track the new pane as secondary
      new_idx=$(tm_info '#{pane_index}')
      [ "$new_idx" -gt 1 ] && tm set-option -w $(_target_args) @secondary "$(tm_info '#{pane_id}')"
      tm resize-pane -Z $(_target_args)
    elif [ "$zoomed" -eq 0 ]; then
      tm resize-pane -Z $(_target_args)
    elif [ "$pane_idx" -eq 1 ]; then
      sec=$(get_secondary)
      tm select-pane -Z -t "$sec"
    else
      tm select-pane -Z -t :.1
    fi
    ;;
  side)
    # Single query for state flags (path queried separately — may contain spaces)
    read -r npanes zoomed <<< "$(tm_info '#{window_panes} #{window_zoomed_flag}')"
    if [ "$npanes" -eq 1 ]; then
      path=$(tm_info '#{pane_current_path}')
      tm split-window -h -l 30% $(_target_args) -c "$path"
      # Track the new pane as secondary
      new_idx=$(tm_info '#{pane_index}')
      [ "$new_idx" -gt 1 ] && tm set-option -w $(_target_args) @secondary "$(tm_info '#{pane_id}')"
    elif [ "$zoomed" -eq 1 ]; then
      sec=$(get_secondary)
      # Single call: unzoom + select (avoids redraw flash between steps)
      tm resize-pane -Z $(_target_args) \; select-pane -t "$sec"
    else
      # Single call: select pane 1 + zoom
      tm select-pane -t :.1 \; resize-pane -Z $(_target_args)
    fi
    ;;
  _get_secondary)
    get_secondary
    ;;
  *)
    echo "Usage: tmux-pane-focus {track|zoom|side}" >&2
    exit 1
    ;;
esac
